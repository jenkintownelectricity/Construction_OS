{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "construction_kernel.schemas.detail_schema",
  "title": "Detail Schema Contract Schema",
  "description": "Schema definition for governed detail schema contracts. Owned by Construction_Kernel. Runtime must validate contracts against this schema and must not define its own.",
  "authority": "Construction_Kernel",
  "type": "object",
  "required": ["contract_id", "version", "authority", "contract_type", "valid_component_roles", "valid_relationship_types"],
  "properties": {
    "contract_id": {
      "type": "string",
      "pattern": "^construction_kernel\\.detail_schema\\."
    },
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "authority": {
      "type": "string",
      "const": "Construction_Kernel"
    },
    "contract_type": {
      "type": "string",
      "const": "governed_detail_schema"
    },
    "description": { "type": "string" },
    "governance_source": { "type": "string" },
    "architecture_source": { "type": "string" },
    "fail_closed_rule": { "type": "string" },
    "detail_fields": {
      "type": "object",
      "required": ["required", "optional"],
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" }
        },
        "optional": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "valid_component_roles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "valid_relationship_types": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "valid_parameter_inputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "canonical_detail_logic_rule": { "type": "string" }
  },
  "additionalProperties": true
}
