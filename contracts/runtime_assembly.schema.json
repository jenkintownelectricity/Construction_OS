{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "0.2",
  "contract_name": "runtime_assembly",
  "description": "Contract schema for runtime assembly model after adapter transformation.",
  "type": "object",
  "required": ["name", "components", "constraints", "source_text"],
  "properties": {
    "name": { "type": "string" },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "constraints": { "type": "array" },
    "source_text": { "type": "string" },
    "metadata": { "type": "object" }
  }
}
