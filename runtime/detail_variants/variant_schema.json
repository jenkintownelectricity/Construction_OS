{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "variant_schema.json",
  "title": "Detail Variant Schema",
  "description": "Schema for derived detail variants. Variants are parameterized versions of canonical details. Variant IDs are derived, not canonical truth.",
  "type": "object",
  "required": ["variant_id", "canonical_detail_id", "parameters", "provenance"],
  "properties": {
    "variant_id": {
      "type": "string",
      "description": "Derived variant identifier. Format: [canonical_detail_id]-V[NNN].",
      "pattern": "^[A-Z_]+-[A-Z_]+-[A-Z_]+-[A-Z_]+-[A-Z_]+-[0-9]{2}-V[0-9]{3}$"
    },
    "canonical_detail_id": {
      "type": "string",
      "description": "The canonical detail family ID from Construction_Kernel. Must remain unchanged.",
      "pattern": "^[A-Z_]+-[A-Z_]+-[A-Z_]+-[A-Z_]+-[A-Z_]+-[0-9]{2}$"
    },
    "parameters": {
      "type": "object",
      "description": "Parameterized values for this variant.",
      "properties": {
        "parapet_height": {"type": "number", "minimum": 4, "maximum": 96, "description": "Parapet height in inches."},
        "membrane_thickness": {"type": "number", "minimum": 0.030, "maximum": 0.120, "description": "Membrane thickness in inches."},
        "pipe_diameter": {"type": "number", "minimum": 0.5, "maximum": 24, "description": "Pipe diameter in inches."},
        "curb_size": {"type": "number", "minimum": 6, "maximum": 72, "description": "Curb dimension in inches."},
        "drain_diameter": {"type": "number", "minimum": 2, "maximum": 12, "description": "Drain diameter in inches."},
        "reglet_depth": {"type": "number", "minimum": 0.25, "maximum": 2.0, "description": "Reglet depth in inches."},
        "joint_width": {"type": "number", "minimum": 0.5, "maximum": 6, "description": "Joint width in inches."},
        "overflow_size": {"type": "number", "minimum": 2, "maximum": 12, "description": "Overflow size in inches."}
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "description": "Provenance tracing back to canonical detail.",
      "required": ["canonical_detail_id", "generation_source", "contract_version"],
      "properties": {
        "canonical_detail_id": {"type": "string"},
        "generation_source": {"type": "string", "const": "variant_generator"},
        "contract_version": {"type": "string"}
      }
    }
  },
  "additionalProperties": false
}
