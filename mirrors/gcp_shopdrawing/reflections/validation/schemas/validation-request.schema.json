{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://construction-os.dev/schemas/gcp-mirror/validation-request.schema.json",
  "title": "Validation Request",
  "description": "Schema for a shop drawing submission package submitted to the validation slice for acceptance evaluation. Represents the complete transmittal envelope with one or more detail records from a GCP-hosted system.",
  "type": "object",
  "required": [
    "submission_id",
    "project_id",
    "submitted_at",
    "submitter",
    "schema_version",
    "records"
  ],
  "properties": {
    "submission_id": {
      "type": "string",
      "pattern": "^SUB-[0-9]{14}-[A-Z0-9]{6}$",
      "description": "Unique submission identifier. Format: SUB-{timestamp}-{random}."
    },
    "project_id": {
      "type": "string",
      "description": "GCP project key for the originating project."
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of submission."
    },
    "submitter": {
      "type": "object",
      "required": ["entity_name", "role"],
      "properties": {
        "entity_name": {
          "type": "string",
          "description": "Name of the submitting entity (e.g., fabricator company name)."
        },
        "role": {
          "type": "string",
          "enum": ["fabricator", "erector", "detailer", "engineer", "architect", "contractor"],
          "description": "Role of the submitting party."
        },
        "contact_email": {
          "type": "string",
          "format": "email"
        },
        "license_number": {
          "type": "string",
          "description": "Professional license or AISC certification number."
        }
      }
    },
    "schema_version": {
      "type": "string",
      "description": "GCP export schema version declared by the submitter."
    },
    "transmittal": {
      "type": "object",
      "description": "Transmittal metadata accompanying the submission.",
      "properties": {
        "transmittal_number": {
          "type": "string",
          "description": "Transmittal tracking number from the submitter."
        },
        "spec_section": {
          "type": "string",
          "description": "Specification section reference (e.g., '05 12 00')."
        },
        "submittal_type": {
          "type": "string",
          "enum": ["initial", "resubmission", "revision", "deferred_approval"],
          "description": "Type of submittal action."
        },
        "previous_submission_id": {
          "type": "string",
          "description": "For resubmissions, the ID of the prior rejected submission."
        },
        "cover_sheet_ref": {
          "type": "string",
          "description": "Reference to the cover sheet document."
        }
      }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "description": "Array of detail records included in this submission.",
      "items": {
        "type": "object",
        "required": ["gcp_record_id", "element_data", "material_data", "dim_block", "meta"],
        "description": "A single detail record conforming to the GCP source detail format.",
        "properties": {
          "gcp_record_id": {
            "type": "string",
            "pattern": "^GCP-SD-[0-9]{12}$"
          },
          "element_data": { "type": "object" },
          "geometry_block": { "type": "object" },
          "material_data": { "type": "object" },
          "dim_block": { "type": "object" },
          "connection_block": { "type": "array" },
          "annotation_block": { "type": "array" },
          "revision_block": { "type": "array" },
          "meta": { "type": "object" }
        }
      }
    },
    "supporting_documents": {
      "type": "array",
      "description": "Optional supporting documents (calculations, MTRs, etc.).",
      "items": {
        "type": "object",
        "properties": {
          "document_id": { "type": "string" },
          "document_type": {
            "type": "string",
            "enum": ["calculation", "material_test_report", "weld_procedure", "inspection_report", "erection_plan", "other"]
          },
          "filename": { "type": "string" },
          "content_hash": { "type": "string" },
          "size_bytes": { "type": "integer" }
        }
      }
    },
    "submission_hash": {
      "type": "string",
      "description": "SHA-256 hash of the entire submission payload for integrity verification."
    }
  },
  "additionalProperties": false
}
