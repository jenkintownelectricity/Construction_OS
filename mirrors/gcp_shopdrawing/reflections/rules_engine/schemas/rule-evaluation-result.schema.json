{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://construction-os.dev/schemas/gcp-mirror/rule-evaluation-result.schema.json",
  "title": "Rule Evaluation Result",
  "description": "Schema for the output of evaluating construction compliance rules against a single normalized shop drawing detail. Contains per-rule results and an aggregate verdict.",
  "type": "object",
  "required": [
    "evaluation_id",
    "detail_id",
    "detail_hash",
    "rule_set_version",
    "evaluated_at",
    "overall_verdict",
    "summary",
    "rule_results"
  ],
  "properties": {
    "evaluation_id": {
      "type": "string",
      "pattern": "^EVAL-[0-9]{12}$",
      "description": "Unique identifier for this evaluation run."
    },
    "detail_id": {
      "type": "string",
      "description": "Canonical detail ID of the evaluated record."
    },
    "detail_hash": {
      "type": "string",
      "description": "SHA-256 hash of the input detail record for audit traceability."
    },
    "rule_set_version": {
      "type": "string",
      "description": "Version of the rule set used in this evaluation."
    },
    "jurisdiction_code": {
      "type": "string",
      "description": "Jurisdiction code governing this evaluation."
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of evaluation completion."
    },
    "overall_verdict": {
      "type": "string",
      "enum": ["compliant", "non_compliant", "conditionally_compliant"],
      "description": "Aggregate compliance verdict."
    },
    "summary": {
      "type": "object",
      "required": ["total_evaluated", "passed", "failed", "warnings", "not_evaluable"],
      "properties": {
        "total_evaluated": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "not_evaluable": { "type": "integer", "minimum": 0 },
        "critical_failures": { "type": "integer", "minimum": 0 },
        "evaluation_duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "rule_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "rule_version", "status"],
        "properties": {
          "rule_id": { "type": "string" },
          "rule_version": { "type": "string" },
          "rule_name": { "type": "string" },
          "category": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "warning", "not_evaluable"]
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "advisory"]
          },
          "message": { "type": "string" },
          "evaluated_value": { "description": "The actual value evaluated." },
          "expected_value": { "description": "The expected value or range." },
          "remediation": { "type": "string" },
          "field_path": { "type": "string" },
          "not_evaluable_reason": { "type": "string" }
        }
      }
    },
    "waivers_applied": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rule_id": { "type": "string" },
          "waiver_id": { "type": "string" },
          "reason": { "type": "string" },
          "approved_by": { "type": "string" },
          "expiry_date": { "type": "string", "format": "date" }
        }
      }
    },
    "lineage": {
      "type": "object",
      "properties": {
        "source_detail_hash": { "type": "string" },
        "normalization_contract_version": { "type": "string" },
        "evaluation_contract_version": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
