# CAD source files
source/**/*.dwg
source/**/*.dxf

# generated geometry (raw ingestor output)
source/**/*.json
# allow governed census, inventory, definition, and validation outputs
!source/barrett/census/*.json
!source/barrett/dxf_inventory_*.json
!source/barrett/definitions/*.json
!source/barrett/validations/*.json
!source/barrett/audits/*.json

# ingestion logs
logs/**
# receipts — ignore contents but allow governed subdirectories
receipts/*
!receipts/barrett_ingestion/
!receipts/trace_ingestion/

# CAD temporary files
*.bak
*.sv$
*.tmp