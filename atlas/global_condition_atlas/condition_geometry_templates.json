{
  "schema_version": "1.0.0",
  "description": "Geometry template references keyed by condition family",
  "template_root": "geometry_templates/",
  "condition_geometry_map": [
    { "condition_family": "parapet",              "conditions": ["PARAPET","COPING","COUNTER_FLASHING"],                                                                        "template_id": "parapet_standard_template",       "template_path": "geometry_templates/roofing/parapet_standard_template.json",                  "view_types": ["section","isometric","plan"],    "parametric_inputs": ["parapet_height_mm","wall_thickness_mm","coping_width_mm"] },
    { "condition_family": "roof_field",           "conditions": ["ROOF_FIELD","TAPERED_FIELD","BALLAST_ZONE","WALKWAY","SOLAR_BALLAST"],                                        "template_id": "roof_field_template",             "template_path": "geometry_templates/roofing/roof_field_template.json",                        "view_types": ["section","plan"],               "parametric_inputs": ["slope_percent","insulation_thickness_mm","membrane_type"] },
    { "condition_family": "roof_edge",            "conditions": ["ROOF_EDGE","EAVE","RIDGE"],                                                                                   "template_id": "roof_edge_template",              "template_path": "geometry_templates/roofing/roof_edge_template.json",                         "view_types": ["section","isometric"],          "parametric_inputs": ["fascia_height_mm","overhang_mm","edge_metal_profile"] },
    { "condition_family": "drain",                "conditions": ["DRAIN","SUMP","SCUPPER"],                                                                                     "template_id": "drain_template",                  "template_path": "geometry_templates/roofing/drain_template.json",                             "view_types": ["section","plan","detail"],      "parametric_inputs": ["drain_diameter_mm","sump_depth_mm","bowl_radius_mm"] },
    { "condition_family": "curb",                 "conditions": ["CURB","SKYLIGHT","HVAC_PENETRATION","EQUIPMENT_SUPPORT"],                                                     "template_id": "curb_standard_template",          "template_path": "geometry_templates/roofing/curb_standard_template.json",                     "view_types": ["section","isometric","plan"],   "parametric_inputs": ["curb_height_mm","curb_width_mm","curb_length_mm"] },
    { "condition_family": "penetration",          "conditions": ["STACK_FLASHING","PITCH_PAN","LIGHTNING_ROD","STRUCTURAL_PENETRATION"],                                        "template_id": "penetration_template",            "template_path": "geometry_templates/roofing/penetration_template.json",                       "view_types": ["section","detail"],             "parametric_inputs": ["pipe_diameter_mm","flashing_height_mm","clamp_type"] },
    { "condition_family": "expansion_joint",      "conditions": ["EXPANSION_JOINT","BUILDING_SEPARATION","CONTROL_JOINT"],                                                      "template_id": "expansion_joint_template",        "template_path": "geometry_templates/structural_transition/expansion_joint_template.json",      "view_types": ["section","plan","isometric"],   "parametric_inputs": ["joint_width_mm","movement_range_mm","cover_type"] },
    { "condition_family": "step_flashing",        "conditions": ["STEP_FLASHING","VALLEY","RIDGE"],                                                                             "template_id": "step_flashing_template",          "template_path": "geometry_templates/roofing/step_flashing_template.json",                     "view_types": ["section","isometric"],          "parametric_inputs": ["step_width_mm","step_height_mm","overlap_mm"] },
    { "condition_family": "green_roof",           "conditions": ["GREEN_ROOF","PLAZA_DECK","PLANTER","FOUNTAIN"],                                                               "template_id": "green_roof_template",             "template_path": "geometry_templates/waterproofing/green_roof_template.json",                  "view_types": ["section","plan"],               "parametric_inputs": ["growing_medium_depth_mm","drainage_layer_mm","protection_board_mm"] },
    { "condition_family": "below_grade",          "conditions": ["BELOW_GRADE_WALL","BELOW_GRADE_SLAB","TUNNEL_ROOF","PODIUM_SLAB"],                                            "template_id": "below_grade_template",            "template_path": "geometry_templates/waterproofing/below_grade_template.json",                 "view_types": ["section","isometric"],          "parametric_inputs": ["depth_below_grade_mm","waterproofing_type","drainage_board_mm"] },
    { "condition_family": "window_wall",          "conditions": ["WINDOW_SILL","WINDOW_HEAD","WINDOW_JAMB","DOOR_SILL","DOOR_HEAD","LOUVER"],                                   "template_id": "window_wall_template",            "template_path": "geometry_templates/avb/window_wall_template.json",                           "view_types": ["section","detail"],             "parametric_inputs": ["rough_opening_width_mm","rough_opening_height_mm","sill_slope_deg"] },
    { "condition_family": "curtain_wall",         "conditions": ["CURTAIN_WALL_BASE","CURTAIN_WALL_HEAD","THRU_WALL_FLASHING","WEEP_SCREED","WALL_BASE"],                       "template_id": "curtain_wall_template",           "template_path": "geometry_templates/avb/curtain_wall_template.json",                          "view_types": ["section","isometric"],          "parametric_inputs": ["mullion_depth_mm","head_clearance_mm","flashing_lap_mm"] },
    { "condition_family": "fireproofing",         "conditions": ["FIRE_RATED_WALL","FIRE_RATED_FLOOR","FIREPROOFING_BEAM","FIREPROOFING_COLUMN","FIRE_DAMPER","FIRESTOP_SLEEVE"],"template_id": "fireproofing_template",           "template_path": "geometry_templates/fireproofing/fireproofing_template.json",                 "view_types": ["section","detail"],             "parametric_inputs": ["rating_hours","spray_thickness_mm","intumescent_type"] },
    { "condition_family": "structural_transition","conditions": ["STRUCTURAL_SLAB_EDGE","COLUMN_BASE"],                                                                          "template_id": "structural_transition_template",  "template_path": "geometry_templates/structural_transition/structural_transition_template.json","view_types": ["section","plan"],               "parametric_inputs": ["slab_depth_mm","edge_form_mm","base_plate_size_mm"] },
    { "condition_family": "membrane_transition",  "conditions": ["MEMBRANE_TRANSITION"],                                                                                         "template_id": "membrane_transition_template",    "template_path": "geometry_templates/roofing/membrane_transition_template.json",               "view_types": ["section","detail"],             "parametric_inputs": ["transition_lap_mm","primer_zone_mm","termination_type"] }
  ]
}
