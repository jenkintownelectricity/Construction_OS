{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://construction-os.validkernel.local/schemas/assembly_primitive.schema.json",
  "title": "Assembly Primitive — Governed Assembly Definition",
  "description": "Schema for fully governed Barrett assembly primitives. Extends normalized detail with warranty envelope, CSI section, and full component definitions.",
  "type": "object",
  "required": [
    "assembly_id", "assembly_version", "node_id",
    "manufacturer_id", "manufacturer_name",
    "condition_type", "system_type",
    "components", "assembly_constraints",
    "lineage", "artifacts_enabled"
  ],
  "properties": {
    "assembly_id": { "type": "string" },
    "assembly_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "node_id": { "type": "string" },
    "manufacturer_id": { "type": "string" },
    "manufacturer_name": { "type": "string" },
    "condition_type": { "type": "string" },
    "system_type": { "type": "string" },
    "csi_section": { "type": "string", "description": "CSI MasterFormat section code" },
    "warranty_envelope": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "term_years": { "type": "integer" },
        "coverage": { "type": "string" },
        "wind_speed_mph": { "type": "integer" },
        "requires_certified_applicator": { "type": "boolean" }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component_id", "name", "material", "position", "required"],
        "properties": {
          "component_id": { "type": "string" },
          "name": { "type": "string" },
          "material": { "type": "string" },
          "position": { "type": "string" },
          "required": { "type": "boolean" },
          "parameters": { "type": "object" },
          "source_block": { "type": "string" },
          "block_count": { "type": "integer" }
        }
      }
    },
    "assembly_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "description", "severity", "check"],
        "properties": {
          "rule_id": { "type": "string" },
          "description": { "type": "string" },
          "severity": { "type": "string", "enum": ["HALT", "WARN"] },
          "check": { "type": "string" }
        }
      }
    },
    "lineage": {
      "type": "object",
      "required": ["source_authority", "created", "created_by", "governance_kernel", "truth_kernel"],
      "properties": {
        "source_authority": { "type": "string" },
        "created": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" },
        "governance_kernel": { "type": "string" },
        "truth_kernel": { "type": "string" }
      }
    },
    "artifacts_enabled": {
      "type": "object",
      "properties": {
        "detail_packet": { "type": "boolean" },
        "compliance_certificate": { "type": "boolean" },
        "svg_overlay": { "type": "boolean" },
        "system_passport": { "type": "boolean" }
      }
    }
  }
}
