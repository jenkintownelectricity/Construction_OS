{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Posture Record",
  "description": "Domain truth object representing the detected posture or situational state of a project topic, derived from evidence and claims.",
  "type": "object",
  "required": ["posture_id", "project_id", "topic", "posture_state", "detection_method", "lineage"],
  "additionalProperties": false,
  "properties": {
    "posture_id": {
      "type": "string",
      "pattern": "^PST-",
      "description": "Unique posture identifier."
    },
    "project_id": {
      "type": "string",
      "description": "Reference to the parent project."
    },
    "topic": {
      "type": "string",
      "description": "Subject or area this posture assessment covers."
    },
    "posture_state": {
      "type": "string",
      "enum": [
        "IN_SCOPE",
        "OUT_OF_SCOPE",
        "UNCLEAR_SCOPE",
        "DESIGN_RESPONSIBILITY_PUSH",
        "WARRANTY_RISK",
        "MISSING_PREREQUISITE",
        "PENDING_UPSTREAM_RESPONSE",
        "CONTRACTOR_OVERDUE",
        "CONTRACTOR_NOT_YET_DUE",
        "CONFLICTING_DIRECTION",
        "APPROVED_BUT_REVERSED",
        "FIELD_CONDITION_VARIANCE",
        "SUBMITTAL_PENDING_REVIEW",
        "SUBMITTAL_BLOCKED_BY_MISSING_INPUT",
        "DOCUMENT_GAP",
        "DOCUMENTATION_MISMATCH",
        "COMMUNICATION_RISK",
        "SCHEDULE_RISK",
        "NEEDS_REVIEW"
      ],
      "description": "Detected posture state for this topic."
    },
    "detection_method": {
      "type": "string",
      "enum": ["RULE_BASED", "HEURISTIC", "MANUAL"],
      "description": "How the posture was detected."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score for the posture assessment (0 to 1)."
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Evidence records supporting this posture assessment."
    },
    "related_claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Claims related to this posture."
    },
    "lineage": {
      "$ref": "#/$defs/lineage",
      "description": "Provenance and traceability metadata."
    }
  },
  "$defs": {
    "lineage": {
      "type": "object",
      "required": ["source_authority", "generated_at", "generated_by"],
      "additionalProperties": false,
      "properties": {
        "source_authority": {
          "type": "string",
          "default": "10-Construction_OS",
          "description": "System or authority that produced this record."
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when this record was generated."
        },
        "generated_by": {
          "type": "string",
          "description": "Identity of the agent or process that generated this record."
        }
      }
    }
  }
}
