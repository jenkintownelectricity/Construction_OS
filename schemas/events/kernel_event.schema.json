{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Construction_OS_Kernel_Event",
  "description": "Governed event schema for Construction OS kernel emissions consumed by VKBUS mirror subscribers.",
  "authority": "L0_ARMAND_LEFEBVRE",
  "version": "v1",
  "type": "object",
  "required": ["event_id", "event_type", "schema_version", "source_repo", "authority_level", "emitted_at", "entity_refs", "payload"],
  "properties": {
    "event_id": { "type": "string", "pattern": "^EVT-[A-Za-z0-9-]+$" },
    "event_type": { "type": "string", "enum": ["kernel.condition_detected", "kernel.assembly_resolved", "kernel.validation_passed", "kernel.validation_failed", "kernel.detail_generated", "kernel.artifact_ready", "kernel.receipt_recorded", "kernel.state_changed"] },
    "schema_version": { "type": "string", "const": "v1" },
    "source_repo": { "type": "string", "const": "10-Construction_OS" },
    "authority_level": { "type": "string", "enum": ["L0", "L1", "L2", "L3"] },
    "emitted_at": { "type": "string", "format": "date-time" },
    "entity_refs": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["entity_id", "entity_type", "registry_id"], "properties": { "entity_id": { "type": "string" }, "entity_type": { "type": "string", "enum": ["system", "assembly", "condition", "material", "rule", "detail", "artifact", "receipt"] }, "registry_id": { "type": "string", "minLength": 1 } }, "additionalProperties": false } },
    "payload": { "type": "object" },
    "correlation_id": { "type": "string" },
    "idempotency_key": { "type": "string" },
    "project_id": { "type": "string" }
  },
  "additionalProperties": false
}
