{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Record",
  "description": "Domain truth object representing a construction project and its core identifying information, parties, and status.",
  "type": "object",
  "required": ["project_id", "project_name", "status", "parties", "created_at"],
  "additionalProperties": false,
  "properties": {
    "project_id": {
      "type": "string",
      "pattern": "^PRJ-",
      "description": "Unique project identifier."
    },
    "project_name": {
      "type": "string",
      "description": "Human-readable name of the project."
    },
    "description": {
      "type": "string",
      "description": "Optional description of the project."
    },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "CLOSED", "ON_HOLD"],
      "description": "Current lifecycle status of the project."
    },
    "parties": {
      "type": "array",
      "description": "Parties involved in the project.",
      "items": {
        "type": "object",
        "required": ["party_id", "role", "name"],
        "additionalProperties": false,
        "properties": {
          "party_id": {
            "type": "string",
            "description": "Unique identifier for the party."
          },
          "role": {
            "type": "string",
            "description": "Role of the party in the project."
          },
          "name": {
            "type": "string",
            "description": "Display name of the party."
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the project record was created."
    },
    "lineage": {
      "$ref": "#/$defs/lineage",
      "description": "Provenance and traceability metadata."
    }
  },
  "$defs": {
    "lineage": {
      "type": "object",
      "required": ["source_authority", "generated_at", "generated_by"],
      "additionalProperties": false,
      "properties": {
        "source_authority": {
          "type": "string",
          "default": "10-Construction_OS",
          "description": "System or authority that produced this record."
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when this record was generated."
        },
        "generated_by": {
          "type": "string",
          "description": "Identity of the agent or process that generated this record."
        }
      }
    }
  }
}
