{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Evidence Record",
  "description": "Domain truth object representing a piece of evidence sourced from project documentation, communications, or field observations.",
  "type": "object",
  "required": ["evidence_id", "project_id", "source_type", "source_date", "source_party_id", "quality_tier", "status", "content_summary", "lineage"],
  "additionalProperties": false,
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^EVD-",
      "description": "Unique evidence identifier."
    },
    "project_id": {
      "type": "string",
      "description": "Reference to the parent project."
    },
    "source_type": {
      "type": "string",
      "enum": [
        "FIELD_OBSERVATION",
        "INSPECTION_REPORT",
        "PHOTO",
        "EMAIL",
        "SUBMITTAL",
        "MEETING_MINUTES",
        "DAILY_REPORT",
        "TEST_RESULT",
        "DRAWING",
        "SPECIFICATION",
        "CONTRACT_DOCUMENT",
        "RFI",
        "CHANGE_ORDER"
      ],
      "description": "Classification of the evidence source."
    },
    "source_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date the evidence was originally produced or observed."
    },
    "source_party_id": {
      "type": "string",
      "description": "Party that produced or provided the evidence."
    },
    "quality_tier": {
      "type": "string",
      "enum": ["PRIMARY", "SECONDARY", "TERTIARY"],
      "description": "Reliability tier of the evidence."
    },
    "extraction_method": {
      "type": "string",
      "enum": ["DIRECT_ENTRY", "DOCUMENT_PARSE", "HEURISTIC_INFERENCE"],
      "description": "How the evidence was extracted or entered into the system."
    },
    "status": {
      "type": "string",
      "enum": ["ADMITTED", "NEEDS_REVIEW", "REJECTED"],
      "description": "Admissibility status of the evidence."
    },
    "content_summary": {
      "type": "string",
      "description": "Human-readable summary of what the evidence shows or states."
    },
    "document_ref": {
      "type": "string",
      "description": "Optional reference to the source document."
    },
    "lineage": {
      "$ref": "#/$defs/lineage",
      "description": "Provenance and traceability metadata."
    }
  },
  "$defs": {
    "lineage": {
      "type": "object",
      "required": ["source_authority", "generated_at", "generated_by"],
      "additionalProperties": false,
      "properties": {
        "source_authority": {
          "type": "string",
          "default": "10-Construction_OS",
          "description": "System or authority that produced this record."
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when this record was generated."
        },
        "generated_by": {
          "type": "string",
          "description": "Identity of the agent or process that generated this record."
        }
      }
    }
  }
}
