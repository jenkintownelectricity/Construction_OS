{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Reconciliation Record",
  "description": "Domain truth object representing the reconciliation of intended, approved, asserted, observed, and documented states for a project topic.",
  "type": "object",
  "required": ["reconciliation_id", "project_id", "topic", "reconciliation_state", "lineage"],
  "additionalProperties": false,
  "properties": {
    "reconciliation_id": {
      "type": "string",
      "pattern": "^RCN-",
      "description": "Unique reconciliation identifier."
    },
    "project_id": {
      "type": "string",
      "description": "Reference to the parent project."
    },
    "topic": {
      "type": "string",
      "description": "Subject or area being reconciled."
    },
    "intended_state": {
      "type": ["string", "null"],
      "description": "What was originally intended or designed."
    },
    "approved_state": {
      "type": ["string", "null"],
      "description": "What was formally approved."
    },
    "asserted_state": {
      "type": ["string", "null"],
      "description": "What a party claims to be the case."
    },
    "observed_state": {
      "type": ["string", "null"],
      "description": "What has been observed in the field."
    },
    "documented_state": {
      "type": ["string", "null"],
      "description": "What the project documentation states."
    },
    "reconciliation_state": {
      "type": "string",
      "enum": [
        "ALIGNED",
        "INTENT_ONLY",
        "REALITY_ONLY",
        "ASSERTED_NOT_EVIDENCED",
        "OBSERVED_NOT_APPROVED",
        "DOCUMENTED_BUT_NOT_OBSERVED",
        "CLAIM_CONFLICT",
        "NEEDS_REVIEW"
      ],
      "description": "Overall reconciliation outcome."
    },
    "divergence_description": {
      "type": "string",
      "description": "Human-readable description of the divergence between states."
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Evidence records relevant to this reconciliation."
    },
    "lineage": {
      "$ref": "#/$defs/lineage",
      "description": "Provenance and traceability metadata."
    }
  },
  "$defs": {
    "lineage": {
      "type": "object",
      "required": ["source_authority", "generated_at", "generated_by"],
      "additionalProperties": false,
      "properties": {
        "source_authority": {
          "type": "string",
          "default": "10-Construction_OS",
          "description": "System or authority that produced this record."
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when this record was generated."
        },
        "generated_by": {
          "type": "string",
          "description": "Identity of the agent or process that generated this record."
        }
      }
    }
  }
}
