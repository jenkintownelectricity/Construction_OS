{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DXF Semantic Enrichment Record",
  "description": "Additive semantic enrichment for a DXF-derived JSON entity. Does not modify raw source JSON.",
  "type": "object",
  "required": ["enrichment_id", "source_file", "entity_index", "ownership_class", "lineage"],
  "properties": {
    "enrichment_id": { "type": "string", "pattern": "^ENR-" },
    "source_file": { "type": "string", "description": "Path to raw DXF JSON file" },
    "entity_index": { "type": "integer", "description": "Index of entity in source JSON entities array" },
    "entity_type": { "type": "string" },
    "layer_name": { "type": "string" },
    "ownership_class": { "type": "string", "enum": ["SYSTEM_OWNED", "CONTEXT_ONLY", "ANNOTATION"] },
    "semantic_role": { "type": "string", "enum": ["membrane", "primer_adhesive", "flashing", "reinforcement", "coating", "protection", "transition", "termination", "sealant", "substrate", "wall", "structure", "overburden", "insulation", "unclassified_context", "annotation"] },
    "classification_method": { "type": "string", "enum": ["LAYER_PATTERN", "ENTITY_TYPE", "OPERATOR_OVERRIDE", "MANUFACTURER_SPEC"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "operator_reviewed": { "type": "boolean" },
    "lineage": {
      "type": "object",
      "required": ["source_authority", "enriched_at"],
      "properties": {
        "source_authority": { "type": "string" },
        "enriched_at": { "type": "string", "format": "date-time" },
        "enriched_by": { "type": "string" },
        "original_dxf_path": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
