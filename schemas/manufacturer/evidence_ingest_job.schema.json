{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence_ingest_job.schema.json",
  "title": "Evidence Ingest Job",
  "description": "Schema for a manufacturer evidence ingest job record. Tracks file upload, storage posture, and extraction status.",
  "type": "object",
  "required": [
    "filename",
    "evidence_kind",
    "processing_status",
    "storage_posture",
    "storage_bucket",
    "storage_object_path",
    "uploaded_at_utc"
  ],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "company_id": { "type": "string", "format": "uuid" },
    "job_id": { "type": "string", "format": "uuid" },
    "submittal_id": { "type": "string", "format": "uuid" },
    "manufacturer_id": { "type": "string", "format": "uuid" },
    "system_family_id": { "type": "string", "format": "uuid" },
    "filename": { "type": "string" },
    "file_extension": { "type": "string" },
    "mime_type": { "type": "string" },
    "evidence_kind": {
      "type": "string",
      "enum": ["dxf_detail", "pdf_submittal", "assembly_letter", "spec_section", "product_data", "field_photo", "test_report", "certification", "other"]
    },
    "processing_status": {
      "type": "string",
      "enum": ["uploaded", "queued", "extracting", "extracted", "failed", "expired"]
    },
    "storage_posture": {
      "type": "string",
      "enum": ["temporary_processing", "queue_safeguarded", "vaulted"]
    },
    "storage_bucket": { "type": "string" },
    "storage_object_path": { "type": "string" },
    "file_size_bytes": { "type": "integer" },
    "uploaded_at_utc": { "type": "string", "format": "date-time" },
    "expires_at_utc": { "type": ["string", "null"], "format": "date-time" },
    "extracted_at_utc": { "type": ["string", "null"], "format": "date-time" },
    "extraction_summary": { "type": ["object", "null"] }
  },
  "additionalProperties": false
}
