{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "system.schema.json",
  "title": "System",
  "description": "Canonical schema for a system, system family, or assembly record in the building envelope domain.",
  "type": "object",
  "required": ["record_id", "type", "label", "domain", "status"],
  "properties": {
    "record_id": {
      "type": "string",
      "description": "Unique identifier for this system record."
    },
    "type": {
      "type": "string",
      "enum": ["system_family", "system", "assembly"]
    },
    "label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "domain": {
      "type": "string",
      "enum": ["building_envelope"]
    },
    "status": {
      "type": "string",
      "enum": ["grounded", "derived", "scaffold", "deferred", "unverified"]
    },
    "system_type": {
      "type": "string",
      "examples": ["adhered", "mechanically_attached", "cavity_wall"]
    },
    "envelope_zone": {
      "type": "string",
      "enum": ["roof", "wall", "foundation", "general"]
    },
    "attachment_method": {
      "type": "string"
    },
    "drainage_type": {
      "type": "string"
    },
    "manufacturer_ref": {
      "type": "string"
    },
    "family_ref": {
      "type": "string"
    },
    "system_ref": {
      "type": "string"
    },
    "condition_ref": {
      "type": "string"
    },
    "scaffold_reason": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
