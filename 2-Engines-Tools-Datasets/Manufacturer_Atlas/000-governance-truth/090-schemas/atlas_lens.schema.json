{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas_lens.schema.json",
  "title": "AtlasLens",
  "description": "Defines a view lens for inspecting a subset of the Manufacturer Atlas knowledge graph.",
  "_lineage": {
    "origin_repo": "10-Construction_OS",
    "origin_path": "2-Engines-Tools-Datasets/Manufacturer_Atlas/schemas/atlas_lens.schema.json",
    "origin_commit": "05a909260769de38eebe839494e2b00c277fbdff",
    "recreated_by": "manufacturer-domain-os-taxonomy-wave",
    "recreated_date": "2026-03-31"
  },
  "type": "object",
  "required": ["lens_id", "name", "description", "emphasized_node_classes", "displayed_relationships", "inspection_capabilities"],
  "properties": {
    "lens_id": { "type": "string", "pattern": "^LENS-[A-Z]+-[0-9]+$" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "emphasized_node_classes": {
      "type": "array",
      "items": { "type": "string", "enum": ["manufacturer", "system_family", "system", "condition", "assembly", "product", "rule", "detail"] },
      "minItems": 1
    },
    "displayed_relationships": {
      "type": "array",
      "items": { "type": "string", "enum": ["contains", "supports", "uses", "governed_by", "compatible_with", "resolved_by", "references", "outputs"] },
      "minItems": 1
    },
    "inspection_capabilities": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
  },
  "additionalProperties": false
}
