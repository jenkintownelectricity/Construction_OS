{
  "sentinel_id": "pipeline_sentinel_v1",
  "rules": [
    {"id": "S001", "check": "generator_output_exists", "warn_if": "geometry JSON missing for registered condition", "severity": "ERROR"},
    {"id": "S002", "check": "renderer_output_exists", "warn_if": "SVG missing when geometry JSON exists", "severity": "ERROR"},
    {"id": "S003", "check": "packet_output_exists", "warn_if": "PDF missing when SVGs exist", "severity": "WARN"},
    {"id": "S004", "check": "client_path_exists", "warn_if": "client/ folder missing when packet exists", "severity": "WARN"},
    {"id": "S005", "check": "canonical_exporter_used", "warn_if": "non-canonical exporter path activated", "severity": "ERROR"},
    {"id": "S006", "check": "no_duplicate_generation", "warn_if": "same artifact generated by 2+ repos", "severity": "ERROR"},
    {"id": "S007", "check": "white_background", "warn_if": "SVG background is not #FFFFFF", "severity": "ERROR"},
    {"id": "S008", "check": "titleblock_present", "warn_if": "DETAIL ATLAS not found in SVG", "severity": "ERROR"},
    {"id": "S009", "check": "callout_key_present", "warn_if": "CALLOUT KEY not found in SVG", "severity": "WARN"},
    {"id": "S010", "check": "not_empty_sheet", "warn_if": "SVG < 2000 bytes (likely empty)", "severity": "ERROR"},
    {"id": "S011", "check": "mirror_freshness", "warn_if": "mirror data older than source by > 7 days", "severity": "WARN"},
    {"id": "S012", "check": "pattern_defs_present", "warn_if": "no pattern defs in rendered SVG (v3 regression)", "severity": "WARN"}
  ]
}
