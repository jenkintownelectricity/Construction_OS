{
  "schema": "truth_tier_unification",
  "version": "1.0.0",
  "project": "JFK_Terminal_1",
  "description": "Defines the three truth tiers and the unification flow from scraped canonical data through project mapping, field intelligence enrichment, packet regeneration, and atlas enrichment.",
  "tiers": {
    "canonical": {
      "tier_id": 0,
      "label": "Canonical Truth",
      "description": "Scraped manufacturer data and typed DNA assembly truth. Source of record. Immutable after ingest.",
      "sources": ["manufacturer_data_scrape", "spec_section_parse", "typed_dna_assembly", "code_compliance_extraction"],
      "mutability": "IMMUTABLE",
      "outputs": ["typed_assembly_kernel", "material_spec_record", "performance_requirement", "code_anchor"]
    },
    "project": {
      "tier_id": 1,
      "label": "Project Truth",
      "description": "JFK Terminal 1 specific mappings: assembly selections, approved RFIs, design decisions, and project variants derived from canonical kernels. References canonical; never overwrites.",
      "sources": ["project_rfi", "approved_submittal", "design_drawing", "architect_directive", "shop_drawing_approval"],
      "mutability": "PROJECT_SCOPED_WRITE",
      "canonical_reference_mode": "read_only_pointer",
      "outputs": ["project_assembly_selection", "zone_assembly_map", "approved_variant_record", "rfi_resolution_record"]
    },
    "field": {
      "tier_id": 2,
      "label": "Field Intelligence",
      "description": "Contractor-originated observations, installer notes, field fixes, inspection findings, and reality capture for JFK T1. Enriches project and triggers revisions. Never mutates tier 0 or tier 1.",
      "sources": ["shop_drawing_correction", "rfi_reference", "submittal_correction", "installer_note", "field_fix", "observed_conflict", "inspection_observation", "reality_capture_ref"],
      "mutability": "FIELD_ENRICHMENT_ONLY",
      "outputs": ["deviation_record", "revision_trigger", "recommendation_enrichment", "packet_regeneration_signal"]
    }
  },
  "unification_flow": [
    { "step": 1, "id": "STEP-SCRAPE", "label": "Scraped Truth Ingest", "from": "manufacturer_source/spec_document", "to": "canonical_truth_tier", "operation": "parse_and_type_to_dna_assembly", "output": "typed_assembly_kernel" },
    { "step": 2, "id": "STEP-DNA", "label": "Typed DNA Assembly", "from": "canonical_truth_tier", "to": "project_truth_tier", "operation": "map_canonical_kernel_to_project_zone", "output": "project_assembly_selection" },
    { "step": 3, "id": "STEP-PROJECT-MAP", "label": "Project Mapping", "from": "project_truth_tier", "to": "zone_assembly_index", "operation": "bind_assembly_to_zone_and_approve_variants", "output": "zone_assembly_map" },
    { "step": 4, "id": "STEP-GEO", "label": "Geo Anchoring", "from": "zone_assembly_map", "to": "atlas_map_surface", "operation": "anchor_zone_to_gps_and_building_footprint", "output": "geo_anchored_zone_record" },
    { "step": 5, "id": "STEP-FIELD", "label": "Field Intel Enrichment", "from": "field_intelligence_tier", "to": "geo_anchored_zone_record", "operation": "append_observations_deviations_corrections", "output": "enriched_zone_record", "constraint": "no_canonical_or_project_mutation" },
    { "step": 6, "id": "STEP-REGEN", "label": "Packet Regeneration", "from": "enriched_zone_record+revision_graph", "to": "packet_store", "operation": "evaluate_revision_queue_and_regenerate_packets", "output": "regenerated_packet", "trigger_ref": "revision_intelligence_graph.json" },
    { "step": 7, "id": "STEP-ATLAS", "label": "Atlas Enrichment", "from": "regenerated_packet+geo_anchored_zone_record", "to": "atlas_map_surface", "operation": "publish_revision_evidence_and_packet_markers", "output": "atlas_enriched_map_state" }
  ],
  "integrity_checks": [
    { "check_id": "IC-001", "description": "Canonical tier ID collision detection — reject any project or field record sharing a canonical kernel ID", "enforcement": "hard_reject" },
    { "check_id": "IC-002", "description": "Field enrichment write-scope validation — reject any field write targeting tier 0 or tier 1 records", "enforcement": "hard_halt" },
    { "check_id": "IC-003", "description": "Packet regeneration gating — blocked packets may not be published until blocking_conditions resolve", "enforcement": "gate" },
    { "check_id": "IC-004", "description": "Atlas marker coherence — every atlas marker must resolve to a valid zone, assembly, or packet record", "enforcement": "validation_warning" }
  ],
  "references": {
    "field_intelligence_schema": "field_intelligence/field_intelligence_schema.json",
    "truth_plane_separation": "field_intelligence/truth_plane_separation.json",
    "revision_intelligence_graph": "projects/JFK_Terminal_1/revisions/revision_intelligence_graph.json",
    "atlas_manifest": "projects/JFK_Terminal_1/project_atlas/atlas_manifest.json"
  }
}
