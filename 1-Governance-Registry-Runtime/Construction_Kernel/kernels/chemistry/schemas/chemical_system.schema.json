{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chemical System",
  "type": "object",
  "required": ["schema_version", "system_id", "title", "chemistry_family", "system_type", "status"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "system_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "chemistry_family": {
      "type": "string",
      "enum": ["polyurethane", "silicone", "polysulfide", "acrylic", "epoxy", "bituminous", "polyolefin", "pvc", "epdm", "butyl", "sbs", "app", "pmma", "polyurea", "hybrid"]
    },
    "system_type": {
      "type": "string",
      "enum": ["sealant", "adhesive", "coating", "primer", "cleaner", "membrane_component"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "draft", "deprecated"]
    },
    "polymer_base": {
      "type": "string"
    },
    "additives": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cure_mechanism_ref": {
      "type": "string"
    },
    "solvent_system_ref": {
      "type": "string"
    },
    "voc_g_per_l": {
      "type": "number"
    },
    "material_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
